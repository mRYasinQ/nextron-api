{
  "name": "nextron-api",
  "version": "0.0.1",
  "description": "Backend API for the Nextron AI account e-commerce platform.",
  "author": "Yasin Abbasi",
  "private": true,
  "license": "MIT",
  "scripts": {
    "preapre": "husky",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:create": "mikro-orm migration:create",
    "db:up": "mikro-orm migration:up",
    "db:down": "mikro-orm migration:down",
    "db:list": "mikro-orm migration:list",
    "db:check": "mikro-orm migration:check",
    "db:fresh": "mikro-orm migration:fresh",
    "console": "node dist/cli.js",
    "console:dev": "ts-node -r tsconfig-paths/register ./src/cli.ts",
    "superuser:create": "pnpm console create-superuser",
    "superuser:create:dev": "pnpm console:dev create-superuser"
  },
  "dependencies": {
    "@mikro-orm/cli": "^7.0.16",
    "@mikro-orm/core": "^7.0.16",
    "@mikro-orm/decorators": "^7.0.16",
    "@mikro-orm/migrations": "^7.0.16",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/sqlite": "^7.0.16",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@swc-node/register": "^1.11.1",
    "bcryptjs": "^3.0.3",
    "bytes": "^3.1.2",
    "cache-manager": "^7.2.8",
    "camelcase-keys": "^10.0.2",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.4.2",
    "lodash": "^4.18.1",
    "ms": "^2.1.3",
    "nest-commander": "^3.20.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "snakecase-keys": "^9.0.2",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/bytes": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "mikro-orm": {
    "configPaths": [
      "./src/configs/mikro-orm.config.ts",
      "./dist/configs/mikro-orm.config.js"
    ]
  }
}
