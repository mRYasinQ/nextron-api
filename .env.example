# Application.
NODE_ENV="" # development | production, default: production
APP_URL="" # String, Example: http://localhost:3000, Default: http://localhost:3000
APP_PORT="" # Number, Example: 3000, Default: 3000
ENABLE_SWAGGER="" # 0: false | 1: true, default 1
CORS_ORIGINS="" # String, Example: http://localhost:3000,http://localhost:3001

# Database.
DB_NAME="" # String, Default: nextron.db

# Time, Example: 2m: 2 minute, 1d: 1 day
OTP_EXPIRE="" # Default: 3m
OTP_CACHE="" # Default: 1d
SESSION_EXPIRE="" # Default: 15d

# Throttle.
THROTTLE_TTL="" # Time, Example: 60m, Default: 60m
THROTTLE_LIMIT="" # Number, Example: 100, Default: 100
